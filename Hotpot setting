tion);}.form-control:focus{border-color:var(--primary-color) !important;box-shadow:0 0 0 3px rgba(255,193,7,0.1) !important;outline:none !important;}.btn{border-radius:8px !important;padding:0.6rem 1.5rem !important;font-weight:500 !im-portant;transition:var(--transition);border:none !important;}.btn-primary{background-color:var(--primary-color) !important;color:#000 !im-portant;}.btn-primary:hover{background-color:#E0A800 !im-portant;transform:translateY(-2px);box-shadow:0 4px 8px rgba(255,193,7,0.2);}.btn-primary:active{transform:translateY(0);}#wifilist{margin-top:1rem;padding:1rem;border-radius:8px;background-color:var(--light-bg);border:1px solid #E5E7EB;min-height:100px;}#wifilist p{margin:0.5rem 0;padding:0.5rem;border-radius:4px;transition:var(--transition);}#wifilist p:hover{background-color:rgba(255,193,7,0.05);}footer{padding:2rem 0 !im-portant;color:var(--secondary-color);border-top:1px solid #E5E7EB;margin-top:2rem;}@media (max-width:768px){header h1{font-size:2.25rem;}.mybox1,.mybox2{padding:1.5rem;}.row>.col-sm{margin-bottom:1.5rem;}.row>.col-sm:last-child{margin-bottom:0;}}@media (max-width:576px){header{padding:1.5rem 0 !important;}.btn{width:100%;margin-bottom:0.75rem !important;}.btn:last-child{margin-bottom:0 !im-portant;}}</style></head><body><header class="container text-center"><h1>OPs Sensor</h1><h2>Wifi Management Portal</h2><p>Save Wifi credentials to enable system reboot, connection to Wifi AP, and full func-tionality of the OPs Sensor.</p></header><main class="container mybox1"><form action="saveSecret" method="POST"><div class="row g-4"><div class="col-sm"><div class="form-box"><label class="form-label">SSID 1</label><input type="text" class="form-control" name="ssid1" id="ssid1" maxlength="32" placeholder="Enter SSID"></div><div class="form-box"><label class="form-label">Password 1</label><input type="password" class="form-control" name="pass1" id="pass1" maxlength="32" placeholder="Enter password"></div></div><div class="col-sm"><div class="form-box"><label class="form-label">SSID 2</label><input type="text" class="form-control" name="ssid2" id="ssid2" maxlength="32" placeholder="Enter SSID"></div><div class="form-box"><label class="form-label">Password 2</label><input type="password" class="form-control" name="pass2" id="pass2" maxlength="32" placeholder="Enter pass-word"></div></div><div class="col-sm"><div class="form-box"><label class="form-label">SSID 3</label><input type="text" class="form-control" name="ssid3" id="ssid3" maxlength="32" placeholder="Enter SSID"></div><div class="form-box"><label class="form-label">Password 3</label><input type="password" class="form-control" name="pass3" id="pass3" maxlength="32" placeholder="Enter pass-word"></div></div></div><div class="mt-4"><button type="reset" class="btn btn-primary">Clear</button><button type="submit" class="btn btn-primary">Save</button></div></form></main><div class="container mybox2"><button class="btn btn-primary" onClick="getWifiScanJson()">Wifi Scan</button><p class="text-muted mt-2 mb-0">Click to scan available Wifi networks</p><div id="wifilist"></div></div><footer class="container text-center fs-6 fw-lighter fst-italic"><p>OPs Sensor Firmware Rev. 2.0</p></footer><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/js/bootstrap.bundle.min.js" integrity="sha384-JEW9xMcG8R+pH31jmWH6WWP0WintQrMb4s7ZOdauHnUtxwoG2vI5DkLtS3qm9Ekf" crossorigin="anonymous"></script></body></html> 
