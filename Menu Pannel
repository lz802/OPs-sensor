<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport"content="width=device-width,initial-scale=1.0"><title>OPs Sensor</title><style>*{margin:0;padding:0;box-sizing:border-box;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;}body{background:#f5f5f5;color:#8b6e2e;}.status-bar{background:#9d7c3c;color:#fff;padding:8px 16px;font-size:14px;display:flex;justify-content:space-between;align-items:center;}.header{padding:40px 24px 20px;display:flex;justify-content:space-between;align-items:center;}.header h1{font-size:2.5rem;font-weight:500;}.header .icon{font-size:1.8rem;}.menu{padding:0 24px;}.menu-item{background:#fff;border-radius:16px;margin-bottom:16px;padding:20px;display:flex;align-items:center;gap:20px;cursor:pointer;}.menu-item .icon{width:60px;height:60px;display:flex;align-items:center;justify-content:center;border:2px solid #8b6e2e;border-radius:50%;font-size:1.5rem;}.menu-item .label{font-size:1.8rem;font-weight:500;}.testing-content{display:none;padding:0 24px;}.testing-header{display:flex;align-items:center;gap:12px;margin-bottom:20px;}.back-btn{font-size:1.8rem;cursor:pointer;}.testing-title{font-size:2rem;font-weight:500;}.panel{background:#eee;border-radius:8px;padding:20px;margin-bottom:20px;}.row{display:flex;align-items:center;gap:12px;margin-bottom:12px;}.label{font-size:1.2rem;width:180px;}.select{padding:8px;border:1px solid #ccc;border-radius:4px;font-size:1rem;min-width:200px;}.value-box{padding:8px;border:1px solid #ccc;border-radius:4px;background:#fff;min-width:150px;font-size:1rem;}.btn{padding:8px 20px;border-radius:4px;font-size:1rem;cursor:pointer;}.btn-refresh{background:#fff;border:1px solid #ccc;}.btn-insect{background:#e0f0ff;border:1px solid #4a90e2;color:#000;}.level-dot{width:20px;height:20px;border-radius:50%;display:inline-block;}.green{background:#4CAF50;}.yellow{background:#FFC107;}.red{background:#F44336;}.legend{margin-top:20px;display:flex;flex-direction:column;gap:8px;}.legend-item{display:flex;align-items:center;gap:8px;}</style></head><body><div class="status-bar"><span>7:32</span><span>📶📻🔋</span></div><div class="header"><h1>OPs Sensor</h1><div class="icon">📶×</div></div><div class="menu"id="mainMenu"><div class="menu-item"><div class="icon">📈</div><div class="label">CV</div></div><div class="menu-item"><div class="icon">📊</div><div class="label">i-t</div></div><div class="menu-item"><div class="icon">📉</div><div class="label">IV</div></div><div class="menu-item"><div class="icon">📈</div><div class="label">DPV</div></div><div class="menu-item"><div class="icon">📊</div><div class="label">SWV</div></div><div class="menu-item"><div class="icon">📉</div><div class="label">NPV</div></div><div class="menu-item"><div class="icon">⚙️</div><div class="label">Setup</div></div><div class="menu-item"onclick="showTesting()"><div class="icon">🧪</div><div class="label">Testing</div></div><div class="menu-item"><div class="icon">ℹ</div><div class="label">About</div></div></div><div class="testing-content"id="testingPage"><div class="testing-header"><div class="back-btn"onclick="showMenu()">←</div><div class="testing-title">Testing</div></div><div class="panel"><div class="row"><div class="label">Type</div><select class="select"><option>Apple</option><option>Banana</option><option>Orange</option></select><div class="label">Baseline</div><select class="select"><option>line 1</option><option>line 2</option><option>line 3</option></select></div><div class="row"><div class="label">Calculated value (ppb)</div><div class="value-box">987.48</div><button class="btn btn-refresh"onclick="refreshValue()">Refresh</button><button class="btn btn-insect"onclick="insect()">Insect</button></div><div class="row"><div class="label"></div><div class="label">Detected</div><select class="select"><option>line 9</option><option>line 10</option><option>line 11</option></select></div><div class="row"><div class="label">Level: <span class="level-dot yellow"></span></div><button class="btn btn-refresh"onclick="refreshLevel()">Refresh</button><button class="btn btn-insect"onclick="insect()">Insect</button></div></div><div class="legend"><div class="legend-item"><span class="level-dot green"></span><span>No (low) CPF Residue (<10 ppb)</span></div><div class="legend-item"><span class="level-dot yellow"></span><span>Detected CPF Residue</span></div><div class="legend-item"><span class="level-dot red"></span><span>Excessive CPF Residue (>1000 ppb)</span></div></div></div><script>function show-Menu(){document.getElementById('mainMenu').style.display='block';document.getElementById('testingPage').style.display='none';}function showTest-ing(){document.getElementById('mainMenu').style.display='none';document.getElementById('testingPage').style.display='block';}function refresh-Value(){document.querySelector('.value-box').textContent=(Math.random()*1000).toFixed(2);}function re-freshLevel(){const val=parseFloat(document.querySelector('.value-box').textContent);const dot=document.querySelector('.level-dot');val<10?dot.className='level-dot green':val>1000?dot.className='level-dot red':dot.className='level-dot yellow';}function insect(){alert('Insect ac-tion triggered');}</script></body></html>
