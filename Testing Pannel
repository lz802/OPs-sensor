<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Testing - OPs Sen-sor</title><style>*{margin:0;padding:0;box-sizing:border-box;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-ser-if;}body{background:#f5f5f5;color:#333;}.header{background:#9d7c3c;color:#fff;padding:12px 16px;display:flex;align-items:center;gap:12px;}.back-btn{font-size:1.2rem;cursor:pointer;}.title{font-size:1.2rem;font-weight:500;}.container{padding:20px;}.panel{background:#eee;border-radius:8px;padding:20px;margin-bottom:20px;}.row{display:flex;align-items:center;gap:12px;margin-bottom:12px;}.label{font-size:1.2rem;width:180px;}.select{padding:8px;border:1px solid #ccc;border-radius:4px;font-size:1rem;min-width:200px;}.value-box{padding:8px;border:1px solid #ccc;border-radius:4px;background:#fff;min-width:150px;font-size:1rem;}.btn{padding:8px 20px;border-radius:4px;font-size:1rem;cursor:pointer;}.btn-refresh{background:#fff;border:1px solid #ccc;}.btn-insect{background:#e0f0ff;border:1px solid #4a90e2;color:#000;}.level-dot{width:20px;height:20px;border-radius:50%;display:inline-block;}.green{background:#4CAF50;}.yellow{background:#FFC107;}.red{background:#F44336;}.legend{margin-top:20px;display:flex;flex-direction:column;gap:8px;}.legend-item{display:flex;align-items:center;gap:8px;}</style></head><body><div class="header"><div class="back-btn" onclick="location.href='index.html'">←</div><div class="title">Testing</div></div><div class="container"><div class="panel"><div class="row"><div class="label">Type</div><select class="select" id="typeSelect"><option>Apple</option><option>Banana</option><option>Orange</option></select><div class="label">Baseline</div><select class="select" id="baselineSelect"><option>line 1</option><option>line 2</option><option>line 3</option></select></div><div class="row"><div class="label">Calculated value (ppb)</div><div class="value-box" id="calcValue">987.48</div><button class="btn btn-refresh" on-click="refreshValue()">Refresh</button><button class="btn btn-insect" on-click="insect()">Insect</button></div><div class="row"><div class="label"></div><div class="label">Detected</div><select class="select" id="detectedSelect"><option>line 9</option><option>line 10</option><option>line 11</option></select></div><div class="row"><div class="label">Level: <span class="level-dot yellow" id="levelDot"></span></div><button class="btn btn-refresh" on-click="refreshLevel()">Refresh</button><button class="btn btn-insect" on-click="insect()">Insect</button></div></div><div class="legend"><div class="legend-item"><span class="level-dot green"></span><span>No (low) CPF Residue (<10 ppb)</span></div><div class="legend-item"><span class="level-dot yellow"></span><span>Detected CPF Resi-due</span></div><div class="legend-item"><span class="level-dot red"></span><span>Excessive CPF Residue (>1000 ppb)</span></div></div></div><script>function refresh-Val-ue(){document.getElementById('calcValue').textContent=(Math.random()*1000).toFixed(2);}function refreshLevel(){const val=parseFloat(document.getElementById('calcValue').textContent);const dot=document.getElementById('levelDot');if(val<10){dot.className='level-dot green';}else if(val>1000){dot.className='level-dot red';}else{dot.className='level-dot yellow';}}function insect(){alert('Insect action triggered');}</script></body></html>
